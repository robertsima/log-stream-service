# Local secrets (never commit)
.env
.env.local

# Agent worktrees
.claude/worktrees/

# Optional frontend override for local backend dev (production default is js/env.js)
frontend/js/env.local.js

# Compiled class file
*.class
__pycache__/

# Node dependencies
node_modules/

# Log file
*.log

# BlueJ files
*.ctxt

# Mobile Tools for Java (J2ME)
.mtj.tmp/

# Package Files #
*.jar
*.war
*.nar
*.ear
*.zip
*.tar.gz
*.rar

# SDK package build output
frontend/sdk/java-logback/target/
frontend/sdk/python/build/
frontend/sdk/python/dist/
frontend/sdk/python/*.egg-info/
frontend/sdk/typescript/dist/
frontend/sdk/typescript/*.tgz

# virtual machine crash logs, see http://www.java.com/en/download/help/error_hotspot.xml
hs_err_pid*
replay_pid*

# Production / Docker backend config. Copy to .env (gitignored).
# On Render/host platforms, set these as dashboard env vars instead of committing them.

PORT=8080

# PostgreSQL (e.g. Neon). Use the full JDBC URL.
DB_URL=jdbc:postgresql://<host>/<database>?sslmode=require
DB_USER=
DB_PASSWORD=

# Comma-separated CORS origins allowed to call the API (your deployed frontend + local dev).
ALLOWED_ORIGINS=https://your-frontend.example,http://localhost:5500,http://127.0.0.1:5500

# Alerts
ALERTS_ENABLED=true
ALERTS_AGGREGATION_WINDOW_MS=60000
ALERTS_MAX_MESSAGES_PER_ALERT=5

# API docs (keep disabled in production)
SWAGGER_UI_ENABLED=false
JWT_ENABLED=false

# Firebase / demo auth
FIREBASE_PROJECT_ID=
# Demo bypass mints dashboard JWTs for DEMO_BYPASS_EMAIL without Firebase.
# Keep false unless this deployment intentionally serves the public demo page.
DEMO_BYPASS_ENABLED=false
DEMO_BYPASS_EMAIL=admin@email.com
DEMO_JWT_SECRET=

# Backend (Spring Boot / Docker)
# Neon example (append ?sslmode=require; port 5432 is default):
# DB_URL=jdbc:postgresql://ep-xxxx.us-east-1.aws.neon.tech/neondb?sslmode=require
DB_URL=jdbc:postgresql://your-host:5432/appdb?sslmode=require
DB_USER=appuser
DB_PASSWORD=change-me
PORT=8080

# Comma-separated frontend origins (no wildcards)
ALLOWED_ORIGINS=https://prairie-log-api.netlify.app,http://localhost:5500,http://127.0.0.1:5500

# Alerts (aggregation window default is 1 minute)
ALERTS_ENABLED=true
ALERTS_AGGREGATION_WINDOW_MS=60000
ALERTS_MAX_MESSAGES_PER_ALERT=5

# Swagger UI and /v3/api-docs (off by default in production)
SWAGGER_UI_ENABLED=false

# Optional JWT for /secured/* routes only (MVP API stays open when false)
# JWT_ENABLED=false
# JWT_ISSUER_URIS=

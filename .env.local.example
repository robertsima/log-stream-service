# Local Spring Boot debug only — referenced by .vscode/launch.json.
# Copy to .env.local (gitignored). Do not use on Render; set env vars in the host dashboard instead.

PORT=8080

DB_URL=jdbc:postgresql://localhost:5432/appdb
DB_USER=appuser
DB_PASSWORD=apppassword

ALLOWED_ORIGINS=http://localhost:5500,http://127.0.0.1:5500,http://localhost:5500,http://127.0.0.1:5500,http://localhost:3000

ALERTS_ENABLED=true
ALERTS_AGGREGATION_WINDOW_MS=60000
ALERTS_MAX_MESSAGES_PER_ALERT=5

SWAGGER_UI_ENABLED=true
JWT_ENABLED=false

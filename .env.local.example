# Local Spring Boot debug only. Copy to .env.local (gitignored).
# Referenced by .vscode/launch.json. Do not use on Render — set host env vars there.

PORT=8080

# PostgreSQL (local)
DB_URL=jdbc:postgresql://localhost:5432/appdb
DB_USER=appuser
DB_PASSWORD=apppassword

# Frontend static dev server origins (Live Server, etc.)
ALLOWED_ORIGINS=http://localhost:5500,http://127.0.0.1:5500,http://localhost:3000

# Alerts
ALERTS_ENABLED=true
ALERTS_AGGREGATION_WINDOW_MS=60000
ALERTS_MAX_MESSAGES_PER_ALERT=5

# Kafka — matches backend/podman/kafka.yaml (PLAINTEXT, no auth)
# IDE launch loads this file via .vscode/launch.json envFile.
KAFKA_INTEGRATION_TOGGLE=true
KAFKA_HOST=localhost
KAFKA_PORT=9092
KAFKA_SERVICE_URI=localhost:9092
KAFKA_USER=
KAFKA_PASS=
KAFKA_CACERT=

# Local API docs
SWAGGER_UI_ENABLED=true
JWT_ENABLED=false

# Firebase / demo auth
FIREBASE_PROJECT_ID=prairie-log-api
DEMO_BYPASS_ENABLED=true
DEMO_BYPASS_EMAIL=admin@email.com
DEMO_JWT_SECRET=replace-with-a-local-dev-secret

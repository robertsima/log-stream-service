{
  "name": "@prairielog/client",
  "version": "0.1.0",
  "description": "TypeScript client for PrairieLog ingestion.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "src",
    "examples",
    "tsconfig.json",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepack": "npm run build"
  },
  "keywords": [
    "prairielog",
    "logging",
    "logs",
    "observability"
  ],
  "license": "MIT",
  "author": "PrairieLog",
  "homepage": "https://prairie-log-api.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/robertsima/log-stream-service.git",
    "directory": "frontend/sdk/typescript"
  },
  "bugs": {
    "url": "https://github.com/robertsima/log-stream-service/issues"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "typescript": "^5.5.0"
  }
}

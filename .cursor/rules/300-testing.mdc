description: Use when adding or changing tests for backend API, services, persistence, alerting, or frontend behavior.
globs:
  - "backend/src/test/**/*.java"
  - "src/test/**/*.java"
  - "**/*Test.java"
  - "**/*IT.java"
alwaysApply: false
